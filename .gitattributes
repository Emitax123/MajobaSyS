# Default behavior: normalize line endings to LF in the repo
* text=auto eol=lf

# Windows batch scripts must use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.pyc binary
*.db binary
*.sqlite3 binary
